# Absolute path to the yt-dlp binary. Leave unset to use "yt-dlp" from PATH.
YTDLP_PATH=

# Absolute path to the ffmpeg binary. Leave unset to use "ffmpeg" from PATH.
FFMPEG_PATH=

# Directory for temporary downloads. Defaults to <project>/downloads.
DOWNLOAD_DIR=

# Max age (minutes) a temp file may live before the cleanup sweep removes it.
TEMP_TTL_MINUTES=30

# Hard cap on a single download in seconds (kills runaway yt-dlp processes).
DOWNLOAD_TIMEOUT_SECONDS=600
